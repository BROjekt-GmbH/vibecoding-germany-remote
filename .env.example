# ---- Entwicklung ----
# Bypass Tailscale-Auth (nur wenn NODE_ENV=development)
DEV_USER_LOGIN=dev@example.com

# SSH-Key-Verschluesselung (generieren: openssl rand -hex 32)
ENCRYPTION_KEY=

# Polling-Intervall fuer tmux-Sessions (ms)
POLL_INTERVAL_MS=2000

# App-Port
PORT=3000

# ---- Produktion (Docker Compose) ----
# Tailscale Auth-Key: https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxx

# Tailnet-Domain (findest du unter https://login.tailscale.com/admin/dns)
# TS_CERT_DOMAIN=dein-tailnet.ts.net
