# ---- Tailscale ----
# Auth-Key erstellen: https://login.tailscale.com/admin/settings/keys
# Empfohlen: Reusable + Ephemeral + Tag "container"
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxx

# Deine Tailnet-Domain (findest du unter https://login.tailscale.com/admin/dns)
# Beispiel: mein-tailnet.ts.net
TS_CERT_DOMAIN=dein-tailnet.ts.net

# ---- PostgreSQL ----
POSTGRES_USER=remote_team
POSTGRES_PASSWORD=SICHERES_PASSWORT_HIER
POSTGRES_DB=remote_team

# ---- App ----
POLL_INTERVAL_MS=2000

# ---- SSH-Keys ----
# Pro Host einen Key als Umgebungsvariable.
# In Coolify: unter "Secrets" eintragen.
# Der Variablenname muss mit dem Wert in der DB (hosts.sshKeyEnvVar) übereinstimmen.
# SSH_KEY_WORK_LAPTOP="-----BEGIN OPENSSH PRIVATE KEY-----..."
# SSH_KEY_HOME_SERVER="-----BEGIN OPENSSH PRIVATE KEY-----..."
